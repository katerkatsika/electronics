        <mxCell id="A6IisU_Nh1rhzxG-rzvF-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=27;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Μετά πρέπει να υπολογίσουμε την τάση που το κύκλωμα &quot;πάει&quot; να&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;παράσχει στη Δίοδο&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Αν είναι μεγαλύτερη ή ίση με 12 V τότε η Δίοδος Zener&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;άγει σε Reversed Bias mode&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(δλδ άγει ως Zener και όχι ως απλή Δίοδος) και η&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;τάση στα άκρα της ΔΕΝ καθορίζεται&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;από την τάση που της &quot;προσφέρει&quot; το κύκλωμα,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;αλλά &quot;επιβάλει&quot; στα άκρα της τάση ίση&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;με αυτή που δίνει ο κατασκευαστής ως V&lt;sub&gt;Z&lt;/sub&gt;,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;δηλαδή εδώ 12 V. Αν είναι μικρότερη από&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;την&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;V&lt;/span&gt;&lt;sub style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Z&lt;/sub&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;τότε η Δίοδος δεν άγει.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="1140" x="1003.52" y="-208.57" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=27;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Υπολογίζουμε λοιπόν πρώτα την &quot;προσφερόμενη&quot; από το κύκλωμα τάση στα άκρα της Διόδου&lt;div&gt;για να διαπιστώσουμε αν είναι μικρότερη ή ίση/μεγαλύτερη από την V&lt;sub&gt;Z&lt;/sub&gt;.&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="1220" x="1004.31" y="70.64" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-2" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=31;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ V_L = \frac{R_L}{R_s + R_L} \cdot V_s = \frac{1}{(0.4 + 1) \cdot 10^3} \cdot 40 \Rightarrow $$" vertex="1">
          <mxGeometry height="100" width="879.28" x="1106.5300000000002" y="222.01999999999998" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-3" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=31;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ \Rightarrow V_L = 28.57 \space Volts $$" vertex="1">
          <mxGeometry height="100" width="359.91" x="1330" y="357.17" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-4" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=31;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$ V_L = 28.57 \space V &amp;gt;&amp;nbsp; V_Z = 12 \space V $$" vertex="1">
          <mxGeometry height="100" width="470.34" x="1300" y="484.24999999999994" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-5" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=27;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Παρατηρούμε ότι:" vertex="1">
          <mxGeometry height="61.06" width="260" x="993.31" y="502.09" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=27;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Άρα η Δίοδος άγει ανάστροφα ως Zener οπότε η τάση στα άκρα της δεν είναι αυτή που&lt;div&gt;της προσφέρει το κύκλωμα (τα 28.57 V) αλλά 12 V.&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="1140" x="999.31" y="609.4" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-8" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=31;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="$$V_D = 12 \space V $$" vertex="1">
          <mxGeometry height="92.59" width="236.13" x="1428.11" y="725.75" as="geometry" />
        </mxCell>
        <mxCell id="tKy1h4OiuQWRj1sqNpuJ-9" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=27;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Η αντίσταση R&lt;sub&gt;L&lt;/sub&gt; είναι συνδεδεμένη παράλληλα με τη Δίοδο,&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;άρα&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(αφού έχει κοινά άκρα&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;με τη Δίοδο)&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;έχει και την ίδια τάση στα άκρα της όπως&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;και η Δίοδος,&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;δλδ 12 V:&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="1330" x="998.39" y="844" as="geometry" />
        </mxCell>
