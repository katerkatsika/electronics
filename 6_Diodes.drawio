        <mxCell id="c14TI68tirpXplxb_Zue-18" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;strokeWidth=3;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="" vertex="1">
