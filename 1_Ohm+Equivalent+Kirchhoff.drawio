        <mxCell id="NTvlcul2Kx7oYE2XKa4I-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$&amp;nbsp; R_2 \cdot R_3 - R_x \cdot R_1 = 0 \space \Rightarrow R_2 \cdot R_3 = R_x \cdot R_1 \Rightarrow&amp;nbsp;\space \frac{R_1}{R_3} = \frac{R_2}{R_x} $$" vertex="1">
