        <mxCell id="uAJjPgr2Vt8wCHlmV934-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=33;labelBackgroundColor=none;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;div style=&quot;&quot;&gt;Στα κυκλώματα των τριών παρακάτω σχημάτων να υπολογιστούν:&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;α) Το ολικό ρεύμα της πηγής καθώς και η παρεχόμενη από αυτήν ισχύς.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;β) Το ρεύμα που διαρρέει την κάθε αντίσταση, την πτώση τάσης καθώς και&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;την ισχύ που καταναλώνεται σε κάθε μία ξεχωριστά και συνολικά.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;(είναι η παρεχόμενη από την πηγή ισχύς ίση με τη συνολικά&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp;καταναλισκώμενη ισχύ από τις αντιστάσεις;)&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="1210" x="112" y="2250" as="geometry" />
        </mxCell>
