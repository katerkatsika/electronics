  <diagram id="glRRJiW6jSqO5XwS2RtD" name="Homework -&gt; Kirchhoff">
    <mxGraphModel dx="3352" dy="2030" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="1700" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="XvfYbYd2v9eAGNlsLQJ6-2" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=33;labelBackgroundColor=none;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;font style=&quot;font-size: 33px;&quot;&gt;Άσκηση 1:&lt;/font&gt;" vertex="1">
          <mxGeometry height="50" width="180" x="-155" y="-10" as="geometry" />
        </mxCell>
        <mxCell id="XvfYbYd2v9eAGNlsLQJ6-3" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=41;fontStyle=5;labelBackgroundColor=none;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;font style=&quot;font-size: 41px;&quot;&gt;&amp;nbsp;Kirchhoff&amp;nbsp;&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="210" x="442" y="-150" as="geometry" />
        </mxCell>
        <mxCell id="XvfYbYd2v9eAGNlsLQJ6-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=33;labelBackgroundColor=none;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;div style=&quot;&quot;&gt;Υπολογίστε:&amp;nbsp;&lt;/div&gt;&lt;div&gt;α) το ρεύμα που διαρρέει το κύκλωμα&amp;nbsp; I = ?&amp;nbsp;&lt;div&gt;b) την πτώση τάσης σε όλες τις αντιστάσεις.&lt;/div&gt;&lt;/div&gt;&lt;div&gt;γ) Την ισχύ που παρέχουν οι πηγές V&lt;sub&gt;1&lt;/sub&gt; και V&lt;sub&gt;2&lt;/sub&gt;&amp;nbsp;ξεχωριστά και συνδυαστικά&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; (προσοχή οι δύο πηγές είναι συνδεδεμένες αντίθετα και όχι σε σειρά!).&lt;/div&gt;&lt;div&gt;δ) Την ισχύ που καταναλώνουν οι 3 αντιστάσεις ξεχωριστά και συνολικά όλες μαζί.&lt;/div&gt;&lt;div&gt;ε) Οι συνδυαστικές απαντήσεις στο γ) και δ) είναι μεταξύ τους ίσες; (δλδ ό,τι παράγεται&lt;/div&gt;&lt;div&gt;είναι ίσο με αυτό που καταναλώνεται).&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Επαναλάβετε την άσκηση (με όλα τα ερωτήματα) αφού αντιστρέψετε την πολωσιμότητα&lt;/div&gt;&lt;div&gt;της πηγής V&lt;sub&gt;1&lt;/sub&gt;&amp;nbsp;(ούτως ώστε οι δύο πηγές να είναι πλέον σε σειρά).&lt;/div&gt;" vertex="1">
          <mxGeometry height="460" width="1410" x="45" y="-10" as="geometry" />
        </mxCell>
        <mxCell id="XvfYbYd2v9eAGNlsLQJ6-5" parent="1" style="verticalLabelPosition=bottom;shadow=0;dashed=0;align=center;html=1;verticalAlign=top;strokeWidth=1;shape=mxgraph.electrical.miscellaneous.monocell_battery;direction=north;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="" vertex="1">
