          <mxGeometry height="60" width="552" x="602" y="138" as="geometry" />
        </mxCell>
        <mxCell id="rpr1rq72buouQPe5a6pG-57" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=17;fontColor=light-dark(#00FFFF,#33FFFF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="$$ .... \Rightarrow I_{\alpha} = \frac{R_2 R_3 - R_x R_1}{R_2 R_x (R_1 + R_3) + (R_2 + R_x) [R_1 R_3 + R_{\alpha} (R_1 + R_3)]} \cdot V_o $$" vertex="1">
