          <mxGeometry height="30" width="80" x="-200.09" y="230" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-48" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Μόνον όταν ικανοποιείται η παραπάνω σχέση το MOSFET άγει (αλλιώς είναι σε αποκοπή)." vertex="1">
          <mxGeometry height="36.28" width="326.1" x="-328.77" y="344.74" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-49" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="ούτως ώστε το ηλεκτρικό πεδίο της πύλης να υπερνικά εκείνο της περιοχής φορτίων χώρου, επιτρέποντας την ανάδυση των φορέων μειονότητας στην επιφάνεια του ημιαγωγού και τη δημιουργία του αγώγιμου διαύλου.." vertex="1">
          <mxGeometry height="73.59" width="326.1" x="-328.77000000000004" y="260" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-51" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Θεωρούμε τώρα σταθερή τάση πύλης (ως προς την πηγή) και μεγαλύτερη της τάσης κατωφλίου V&lt;sub&gt;GS&lt;/sub&gt; &amp;gt; V&lt;sub&gt;T&lt;/sub&gt;.&amp;nbsp;" vertex="1">
          <mxGeometry height="30" width="627.53" x="-622.53" y="490" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-52" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Με την εφαρμογή θετικής τάσης στην εκροή (drain - D) αντισταθμίζεται η τάση της πύλης η οποία αποτελεί το αίτιο της δημιουργίας του αγώγιμου διαύλου." vertex="1">
          <mxGeometry height="40" width="617.53" x="-622.53" y="530" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-53" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Για μηδενική ή πολύ μικρή τάση εκροής το κανάλι αγωγιμότητας δεν επηρεάζεται ιδιαίτερα." vertex="1">
          <mxGeometry height="40" width="552.74" x="-622.74" y="580" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-54" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Αυξάνοντας όμως την τάση εκροής το κανάλι γίνεται όλο και πιο ρηχό από την πλευρά της εκροής - στενεύοντάς το. Αυτό έχει ως αποτέλεσμα τη μείωση της αγωγιμότητας του (και αντίστοιχη αύξηση της αντίστασής του) και άρα το ρεύμα δεν αυξάνει με τον ίδιο ρυθμό." vertex="1">
          <mxGeometry height="50" width="653.67" x="-624.06" y="900" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-55" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Η προοδευτική στένωση του καναλιού συνεχίζεται μέχρι το σημείο που διαρρηγνύεται όταν η τάση στην εκροή &quot;πιάσει&quot; μία ορισμένη τιμή V&lt;sub&gt;Dsat&amp;nbsp;&lt;/sub&gt;(ή V&lt;sub&gt;DSsat&lt;/sub&gt;).&lt;div&gt;&lt;br&gt;&lt;div&gt;Από αυτήν την τιμή και πάνω για την τάση εκροής, το βάθος του καναλιού έχει μηδενιστεί από την πλευρά της εκροής.&lt;/div&gt;&lt;div&gt;Το ρεύμα δεν αυξάνει περαιτέρω αλλά παραμένει σταθερό (πιάνει ένα πλατό) και είναι ανεξάρτητο της τάσης εκροής.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="684.06" x="-627.75" y="1530" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-56" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="234" width="627.17" x="-622.74" y="630" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-57" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="240" width="651.02" x="-624.0600000000001" y="980" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-58" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="240" width="655.18" x="-626.14" y="1250" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-59" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="250" width="668.16" x="-627.75" y="1700" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-60" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Στην περίπτωση αυτή το MOSFET βρίσκεται σητν περιοχή του ΚΟΡΟΥ (saturation region) και η τάση V&lt;sub&gt;Dsat&amp;nbsp;&lt;/sub&gt;(ή V&lt;sub&gt;DSsat&lt;/sub&gt;) ονομάζεται τάση κόρου. Στην περιοχή κόρου το MOSFET λειτουργεί ως πηγή ρεύματος σε κυκλώματα ενίσχυσης.&lt;div&gt;Επομένως ο ενεργός τρόπος λειτουργίας (active mode) είναι όταν το MOSFET λειτουργεί στην περιοχή του κόρου.&lt;/div&gt;&lt;div&gt;(συχνά η περιοχή του κόρου αναφέρεται ως ενεργός περιοχή).&lt;/div&gt;" vertex="1">
          <mxGeometry height="70" width="684.06" x="-627.75" y="1620" as="geometry" />
        </mxCell>
        <mxCell id="XqbLf8pCJ3QwVX5BRnOa-1" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="(Ωμική περιοχή)" vertex="1">
          <mxGeometry height="30" width="100" x="6.649999999999999" y="2395.69" as="geometry" />
        </mxCell>
