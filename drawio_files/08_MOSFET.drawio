        <mxCell id="OxmnpSL2i8SNsWTSDrgf-18" parent="1" style="text;strokeColor=none;align=center;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Metal&lt;div&gt;Oxide&lt;/div&gt;&lt;div&gt;Semiconductor&lt;/div&gt;" vertex="1">
          <mxGeometry height="50" width="90" x="-666" y="-338" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-19" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Τοποθετούμε ένα μεταλλικό ηλεκτρόδιο (πύλη - Gate) και για να αποφύγουμε την ηλεκτρική επαφή μεταξύ του ηλεκτροδίου και του ημιαγωγού/υποστρώμτος παρεμβάλουμε ένα λεπτό στρώμα διηλεκτρικού (μονωτή).&amp;nbsp;" vertex="1">
          <mxGeometry height="75" width="303.67" x="-363.67" y="-273" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-20" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Εφαρμόζοντας θετική ηλεκτρική τάση στην πύλη (G) - ως προς το υπόστρωμα ενν. - δημιουργείται ένα ηλεκτρικό πεδίο το οποίο έλκει τα ηλεκτρόνια (φορείς μειονότητας) του υποστρώματος και απωθεί τις οπές (φορείς πλειονότητας)." vertex="1">
          <mxGeometry height="70" width="303.67" x="-363.67" y="-192" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-21" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Έτσι δημιουργείται ένας αγώγιμος δίαυλος στην επιφάνεια που ενώνει τις δύο περιοχές τύπου n." vertex="1">
          <mxGeometry height="30" width="313.67" x="-363.67" y="-115" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-22" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Έχοντας λοιπόν την πύλη σε θετικό δυναμικό (πρέπει όμως να είναι και πάνω από μία τιμή V&lt;sub&gt;T&lt;/sub&gt;) αν συνδέσουμε ηλεκτρικά τις δύο περιοχές τύπου n τότε μπορεί να διέλθει ρεύμα μέσω του επαγόμενου καναλιού στην επιφάνεια μεταξύ των περιοχών αυτών.&amp;nbsp;" vertex="1">
          <mxGeometry height="80" width="326.1" x="-363.67" y="-79" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-23" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Οπότε: Με μηδενικό ή αρνητικό δυναμικό στην πύλη δε δημιουργείται το αγώγιμο κανάλι στην επιφάνεια οπότε το MOSFET είναι στην ΑΠΟΚΟΠΗ (δεν περνάει ρεύμα).&lt;div&gt;Με ικανό θετικό δυναμικό στην πύλη το MOSFET ΆΓΕΙ.&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="326.1" x="-363.67" y="10" as="geometry" />
        </mxCell>
        <mxCell id="OxmnpSL2i8SNsWTSDrgf-24" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;whiteSpace=wrap;rounded=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="Επομένως, το MOSFET μπορεί να λειτουργεί ως διακόπτης ελεγχόμενος από τάση (ιδιότητα που εκμεταλλευόμαστε στην κατασκευή ψηφιακών κυκλωμάτων." vertex="1">
          <mxGeometry height="40" width="480" x="-551.3100000000001" y="100" as="geometry" />
        </mxCell>
