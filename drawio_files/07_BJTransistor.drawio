        <mxCell id="jV8-uy3i1ALxIL3KJ3Bl-8" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="&quot;Κλέβουμε&quot; ένα&amp;nbsp;&lt;span style=&quot;text-align: center;&quot;&gt;e&lt;/span&gt;&lt;sup style=&quot;text-align: center;&quot;&gt;-&lt;/sup&gt;&amp;nbsp;από την p1 και το μεταφέρουμε στην p2&amp;nbsp;&lt;div&gt;και για να διατηρηθεί η&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ισορροπία φορτίου &quot;επιστρέφουμε&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ένα&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;e&lt;/span&gt;&lt;sup style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;-&lt;/sup&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;από&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;την n2 στην n1.&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap; color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%CE%9F%20%CE%B1%CF%81%CE%B9%CE%B8%CE%BC%CF%8C%CF%82%20%CF%84%CF%89%CE%BD%20%CE%B5%CE%BB%CE%B5%CF%8D%CE%B8%CE%B5%CF%81%CF%89%CE%BD%26amp%3Bnbsp%3B%26lt%3Bspan%20style%3D%26quot%3Btext-align%3A%20center%3B%26quot%3B%26gt%3Be%26lt%3B%2Fspan%26gt%3B%26lt%3Bsup%20style%3D%26quot%3Btext-align%3A%20center%3B%26quot%3B%26gt%3B-%26lt%3B%2Fsup%26gt%3B%26amp%3Bnbsp%3B%26amp%3Bnbsp%3B%26amp%3Bgt%3B%26amp%3Bgt%3B%20%CE%B1%CF%80%CF%8C%20%CF%84%CE%BF%CE%BD%20%CE%B1%CF%81%CE%B9%CE%B8%CE%BC%CF%8C%20%CF%84%CF%89%CE%BD%20%CE%BF%CF%80%CF%8E%CE%BD.%26lt%3Bdiv%26gt%3B%CE%86%CF%81%CE%B1%20%CE%B7%20%CE%B1%CE%B3%CF%89%CE%B3%CE%B9%CE%BC%CF%8C%CF%84%CE%B7%CF%84%CE%B1%20%CE%BF%CF%86%CE%B5%CE%AF%CE%BB%CE%B5%CF%84%CE%B1%CE%B9%20%CE%BA%CF%85%CF%81%CE%AF%CF%89%CF%82%20%CF%83%CF%84%CE%B7%CE%BD%20%CE%BA%CE%AF%CE%BD%CE%B7%CF%83%CE%B7%20%CF%84%CF%89%CE%BD%26amp%3Bnbsp%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%20text-align%3A%20center%3B%26quot%3B%26gt%3Be%26lt%3B%2Fspan%26gt%3B%26lt%3Bsup%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%20text-align%3A%20center%3B%26quot%3B%26gt%3B-%26lt%3B%2Fsup%26gt%3B%26lt%3Bspan%20style%3D%26quot%3Bbackground-color%3A%20transparent%3B%20color%3A%20light-dark(rgb(0%2C%200%2C%200)%2C%20rgb(255%2C%20255%2C%20255))%3B%26quot%3B%26gt%3B(%CE%BA%CE%B1%CE%B9%20%CF%80%CE%BF%CE%BB%CF%8D%20%CE%BB%CE%B9%CE%B3%CF%8C%CF%84%CE%B5%CF%81%CE%BF%20%CF%83%CF%84%CE%B7%CE%BD%20%CE%BA%CE%AF%CE%BD%CE%B7%CF%83%CE%B7%20%CF%84%CF%89%CE%BD%20%CE%BF%CF%80%CF%8E%CE%BD).%26lt%3B%2Fspan%26gt%3B%26lt%3B%2Fdiv%26gt%3B%22%20style%3D%22text%3BstrokeColor%3Dnone%3Balign%3Dleft%3BfillColor%3Dnone%3Bhtml%3D1%3BverticalAlign%3Dmiddle%3Brounded%3D0%3BfontSize%3D12%3Bmovable%3D0%3Bresizable%3D0%3Brotatable%3D0%3Bdeletable%3D0%3Beditable%3D0%3Blocked%3D1%3Bconnectable%3D0%3BspacingTop%3D0%3Bspacing%3D3%3BwhiteSpace%3Dwrap%3BspacingLeft%3D1%3B%22%20vertex%3D%22