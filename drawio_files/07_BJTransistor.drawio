        <mxCell id="jV8-uy3i1ALxIL3KJ3Bl-3" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Ο αριθμός των ελεύθερων&amp;nbsp;&lt;span style=&quot;text-align: center;&quot;&gt;e&lt;/span&gt;&lt;sup style=&quot;text-align: center;&quot;&gt;-&lt;/sup&gt;&amp;nbsp;&amp;nbsp;&amp;gt;&amp;gt; από τον αριθμό των οπών.&lt;div&gt;Άρα η αγωγιμότητα οφείλεται κυρίως στην κίνηση των&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;e&lt;/span&gt;&lt;sup style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); text-align: center;&quot;&gt;-&lt;/sup&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(και πολύ λιγότερο στην κίνηση των οπών).&lt;/span&gt;&lt;/div&gt;" vertex="1">
