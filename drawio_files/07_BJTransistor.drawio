        <mxCell id="jV8-uy3i1ALxIL3KJ3Bl-5" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Αν V&lt;sub&gt;1&lt;/sub&gt; &amp;gt;&amp;gt; V&lt;sub&gt;T&lt;/sub&gt; τότε στην #1 pn περνάει ρεύμα&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;και η R&lt;sub&gt;1&lt;/sub&gt; = 0&lt;/span&gt;&lt;div&gt;(ουσιαστικά είναι η R&lt;sub&gt;D&lt;/sub&gt; που όμως&lt;/div&gt;&lt;div&gt;είναι της τάξεως του 1 Ω).&lt;/div&gt;" vertex="1">
