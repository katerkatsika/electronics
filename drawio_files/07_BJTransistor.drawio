        <mxCell id="jV8-uy3i1ALxIL3KJ3Bl-12" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Αν αυξήσουμε το ποσοστό των&amp;nbsp;&lt;span style=&quot;text-align: center;&quot;&gt;e&lt;/span&gt;&lt;sup style=&quot;text-align: center;&quot;&gt;-&lt;/sup&gt;&amp;nbsp;που &quot;υποκλέπτουμε&quot; από την p1, τροφοδοτώντας τα στο αντίστοιχο p2, μειώνουμε ακόμα&amp;nbsp;&lt;div&gt;περισσότερο την αγωγιμότητα της&amp;nbsp; #1 pn (αυξάνοντας αντίστοιχα την αντίστασή της R&lt;sub&gt;1&lt;/sub&gt;) ενώ αυξάνουμε την αγωγιμότητα της&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;#2 pn&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;(μειώνοντας αντίστοιχα την αντίστασή της R&lt;/span&gt;&lt;sub style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;2&lt;/sub&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;).&lt;/span&gt;&lt;span style=&quot;background-color: transparent; text-wrap-mode: nowrap; color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%CE%9F%20%CE%B1%CF%81%CE%B9%CE%B8%CE%BC%CF%8C%CF%82%20%CF%84%CF%89%CE%BD%20%CE%B5%CE%BB%CE%B5%CF%8D%CE%B8%CE%B5%CF%81%CF%89%CE%BD%26amp%3Bnbsp%3B%26lt%3Bspan%20style%3D%26quot%3Btext-align%3A%20center%3B%26quot%3B%26gt%3Be%26lt%3B%2Fspan%26gt%3B%26lt%3Bsup%20style%3D%26quot%3Btext-align%3A%20center%3B%26quot%3B%26gt%3B-%26lt%3B%2Fsup%26gt%3B%26amp%3Bnbsp%3B%26amp