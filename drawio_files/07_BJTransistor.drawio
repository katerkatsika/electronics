          <mxGeometry height="30" width="81.66" x="211.09" y="1260" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-7" parent="1" style="whiteSpace=wrap;html=1;fillColor=none;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="" vertex="1">
          <mxGeometry height="40" width="80" x="208" y="1255" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-8" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Ο συντελεστής β ονομάζεται απολαβή ρεύματος.&lt;div&gt;Όσο το κλάσμα υποκλοπής α πλησιάζει τη μονάδα, τόσο το β μεγαλώνει&amp;nbsp;&lt;/div&gt;&lt;div&gt;(το α δε μπορεί να γίνει = 1 καθώς μηδενίζεται ο παρονομαστής και θα μηδενίζονταν εντελώς το Ι&lt;sub&gt;1&lt;/sub&gt;).&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="419.83" x="40.17" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-9" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=none;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="260" width="290.18" x="80" y="1610" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-10" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="&lt;div&gt;Η διάταξη αυτή λοιπόν λειτουργεί ως πηγή ρεύματος ελεγχόμενη από ρεύμα: δλδ η τιμή του ρεύματος Ι&lt;sub&gt;2&lt;/sub&gt; που διαρρέει την #2 pn εξαρτάται (ελέγχεται) από την τιμή του ρεύματος Ι&lt;sub&gt;1&lt;/sub&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;που διαρρέει την #1 pn.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="410" x="40.17" y="1430" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-11" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Μία τέτοια πηγή με μεγάλη απολαβή ρεύματος (β) μπορεί να επιτελεί&amp;nbsp;&lt;div&gt;ενίσχυση (ρεύματος ενν.) και χρησιμοποιείται σε κυκλώματα ενισχυτών.&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="429.83" x="40.17" y="1500" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-12" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Στην πραγματικότητα οι δύο p περιοχές (κάτω) είναι &quot;συνενωμένες&quot; ως μία&amp;nbsp;&lt;div&gt;ΚΟΙΝΗ ΒΑΣΗ οπότε τα ηλεκτρόνια που φθάνουν από την n1 στην p1&amp;nbsp;&lt;/div&gt;&lt;div&gt;να μπορούν να διαχέονται στην p2.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Η &quot;επιστροφή&quot; δε των &quot;πλεοναζόντων&quot; ηλεκτρονίων από την περιοχή n2 πίσω στην n1 (πάνω) γίνεται με απλή ηλεκτρική σύνδεση των δύο n περιοχών.&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="454.34" x="415.66" y="1600" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-13" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Οι τιμές V&lt;sub&gt;1&lt;/sub&gt;&amp;nbsp;και V&lt;sub&gt;2&lt;/sub&gt; πρέπει να είναι τέτοιες ώστε η #1 pn επαφή να είναι ΟΡΘΑ ΠΟΛΩΜΕΝΗ και η #1 pn επαφή να είναι ΑΝΑΣΤΡΟΦΑ ΠΟΛΩΜΕΝΗ." vertex="1">
          <mxGeometry height="60" width="454.34" x="415.66" y="1710" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-14" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Επειδή το τμήμα n1 &quot;εκπέμπει¨τα ηλεκτρόνια που &quot;κυκλοφορούν&quot; στο transistor&lt;div&gt;το ονομάζουμε Εκπομπό (Emitter).&amp;nbsp; &amp;nbsp; &quot;E&quot;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;To τμήμα n2 &quot;συλλέγει&quot; τα ηλεκτρόνια αυτά και το ονομάζουμε Συλλέκτη (Collector).&amp;nbsp; &quot;C&quot;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Τέλος κοινό τμήμα τύπου p των δύο επαφών το ονομάζουμε Βάση (Base).&amp;nbsp; &amp;nbsp;&quot;B&quot;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="514.34" x="415.66" y="1800" as="geometry" />
        </mxCell>
