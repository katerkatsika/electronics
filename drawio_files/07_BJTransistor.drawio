        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-4" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="Διαιρώντας (1) / (2):" vertex="1">
          <mxGeometry height="30" width="120" x="40.5" y="1150" as="geometry" />
        </mxCell>
        <mxCell id="jpgRXIRZ3x7-U3ilZg9E-5" parent="1" style="text;strokeColor=none;align=left;fillColor=none;html=1;verticalAlign=middle;rounded=0;fontSize=12;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;spacingTop=0;spacing=3;whiteSpace=wrap;spacingLeft=1;labelBackgroundColor=none;" value="$$ \frac{I_2}{I_1} =&amp;nbsp; \frac{\alpha \cdot I}{(1 - \alpha) \cdot I}&amp;nbsp; =&amp;nbsp;&amp;nbsp;\frac{\alpha}{1 - \alpha} = \beta \Rightarrow \space \space$$" vertex="1">
