        <mxCell id="H2dItVX0zvM76HZTqIkN-33" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;labelBorderColor=#FF3399;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;labelBackgroundColor=none;" value="&lt;div&gt;&lt;font style=&quot;font-size: 41px;&quot;&gt;Να βρεθούν τα&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 41px; background-color: initial;&quot;&gt;ισοδύναμα&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 41px; background-color: initial;&quot;&gt;Thevenin και Norton&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial; font-size: 41px;&quot;&gt;όπως φαίνεται&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-size: 41px;&quot;&gt;στα άκρα AB&lt;/span&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
