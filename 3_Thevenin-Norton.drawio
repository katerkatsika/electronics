        </mxCell>
        <mxCell id="THXh5LZG3UX40T9iuK59-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;labelBackgroundColor=none;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=50;" value="&lt;u style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 61px;&quot;&gt;Ισοδύναμο Thevenin&lt;/font&gt;&lt;/u&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;1/ Αφαιρούμε την R&lt;sub&gt;L&lt;/sub&gt;&amp;nbsp;αν υπάρχει (και μένουν ανοικτά τα άκρα - έστω ΑΒ)&lt;/div&gt;&lt;div style=&quot;&quot;&gt;2/ Αποσυνδέουμε τις πηγές&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Πηγές Τάσης τις Βραχυκυκλώνουμε&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Πηγές Ρεύματος τις Ανοιχτοκυκλώνουμε&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;3/ Βρίσκουμε την Ισοδύναμη Αντίσταση όπως φαίνεται από τα άκρα ΑΒ.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;4/ Επαναφέρουμε τις πηγές κρατώντας ΑΝΟΙΧΤΑ τα άκρα ΑΒ.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;5/ Βρίσκουμε την τάση που βλέπουν τα άκρα ΑΒ (Κανόνες Kirchhoff, Διαιρέτες Τάσης)&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="640" width="2070" x="-3936.69" y="-742" as="geometry" />
        </mxCell>
        <mxCell id="THXh5LZG3UX40T9iuK59-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontStyle=1;labelBackgroundColor=none;movable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;fontSize=50;" value="&lt;u style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 61px;&quot;&gt;Ισοδύναμο Norton&lt;/font&gt;&lt;/u&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;1/ Αφαιρούμε την R&lt;sub&gt;L&lt;/sub&gt;&amp;nbsp;αν υπάρχει&amp;nbsp;&lt;span style=&quot;background-color: initial;&quot;&gt;(και μένουν ανοικτά τα άκρα - έστω ΑΒ)&lt;/span&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;.&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;2/ Αποσυνδέουμε τις πηγές&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Πηγές Τάσης τις Βραχυκυκλώνουμε&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;- Πηγές Ρεύματος τις Ανοιχτοκυκλώνουμε&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;3/ Βρίσκουμε την Ισοδύναμη Αντίσταση όπως φαίνεται από τα άκρα ΑΒ.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;4/ Επαναφέρουμε τις πηγές ΒΡΑΧΥΚΥΚΛΩΝΟΝΤΑΣ τα άκρα ΑΒ.&lt;/div&gt;&lt;div style=&quot;&quot;&gt;5/ Βρίσκουμε το ρεύμα που διέρχεται από τα ΑΒ (Κανόνες Kirchhoff, Διαιρέτες Ρεύματος).&lt;/div&gt;&lt;div style=&quot;&quot;&gt;---&amp;gt; &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Αν έχουμε ήδη βρει το ισοδύναμο κατά Thevenin τότε μπορούμε να βρούμε το Ρεύμα Norton&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;από τον λόγο I&lt;sub&gt;N&lt;/sub&gt; = V&lt;sub&gt;TH&lt;/sub&gt; / R&#39;.&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="820" width="2464.91" x="-3958.0899999999997" y="250" as="geometry" />
        </mxCell>
